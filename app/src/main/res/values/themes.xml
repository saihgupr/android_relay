<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AndroidRelay" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary_light</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Enable focus styling for TV navigation -->
        <item name="buttonStyle">@style/Widget.App.Button</item>
        <item name="editTextStyle">@style/Widget.App.EditText</item>
    </style>
</resources>
