<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_panel"
        android:padding="24dp"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Android Relay Logo"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android Relay"
            android:textSize="26sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Checking..."
            android:textColor="@color/primary_light"
            android:textStyle="bold"
            android:textSize="18sp" />

        <Button
            android:id="@+id/permission_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Grant Notification Permission"
            android:contentDescription="Grant permission required to read media states" />

        <TextView
            android:id="@+id/adb_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="@color/surface_dark"
            android:text="If button fails on TV, run via ADB:\nadb shell cmd notification allow_listener com.saihgupr.androidrelay/.MediaSessionListenerService"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAlignment="center" />
    </LinearLayout>

    <!-- MQTT Configuration Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="MQTT Configuration"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/mqtt_broker_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Broker IP (e.g., 192.168.1.199)"
            android:inputType="text"
            android:importantForAccessibility="yes" />

        <EditText
            android:id="@+id/mqtt_topic_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="Topic (e.g., android_tv/playback_state)"
            android:inputType="text"
            android:importantForAccessibility="yes" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/test_mqtt_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Test Connection" />

            <Button
                android:id="@+id/save_config_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save &amp; Restart" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
