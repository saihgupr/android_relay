<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- Header Section -->
        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android Relay"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/header_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Media playback relay to Home Assistant"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Service Status"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Checking..."
                android:textSize="17sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/permission_button"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Grant Permission"
                android:textColor="@color/btn_secondary_text_selector"
                android:textSize="14sp"
                android:paddingHorizontal="20dp"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/adb_instructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:text="Grant via ADB:\nadb shell cmd notification allow_listener com.saihgupr.androidrelay/.MediaSessionListenerService"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:visibility="gone" />

        </LinearLayout>

        <!-- MQTT Configuration Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MQTT Configuration"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-medium" />

            <EditText
                android:id="@+id/mqtt_broker_edit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="Broker IP (e.g., 192.168.1.199)"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:paddingVertical="0dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/mqtt_topic_edit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Topic (e.g., android_tv/playback_state)"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:paddingVertical="0dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <!-- Authentication Toggle -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/mqtt_auth_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Use Authentication"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <!-- Authentication Fields Container -->
            <LinearLayout
                android:id="@+id/mqtt_auth_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/mqtt_username_edit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="Username"
                    android:inputType="text"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="0dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/mqtt_password_edit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_input"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="0dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- Test Connection Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="start">

                <Button
                    android:id="@+id/test_mqtt_button"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Test Connection"
                    android:textColor="@color/btn_secondary_text_selector"
                    android:textSize="14sp"
                    android:paddingHorizontal="20dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/test_result_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:background="@color/divider" />

            <Button
                android:id="@+id/save_config_button"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary"
                android:text="Save and Restart Service"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
